services:
  - type: web
    name: emtap-backend
    env: docker
    plan: starter
    dockerfilePath: backend/Dockerfile
    envVars:
      - key: ENVIRONMENT
        value: prod
      - key: DEFAULT_LLM_PROVIDER
        value: mock
      - key: DEFAULT_EMBEDDING_PROVIDER
        value: mock
      - key: JWT_SECRET_KEY
        sync: false
      - key: DATABASE_URL
        sync: false
      - key: REDIS_URL
        sync: false
